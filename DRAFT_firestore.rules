rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PRODUCTS ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        // Action: Generic Edit
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'price', 'weight', 'category', 'thumbnail', 'videoPreview', 'creator', 'stats', 'formats', 'description', 'rating', 'reviews', 'isHero', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'weight', 'category', 'thumbnail', 'creator', 'stats', 'formats', 'description']) &&
             data.title is string && data.title.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.weight is number && data.weight >= 0 &&
             data.category in ['Character', 'Environment', 'Vehicle', 'Prop', 'Weapon'] &&
             data.thumbnail is string && data.thumbnail.size() <= 1000 &&
             data.creator is string && data.creator.size() <= 100 &&
             data.description is string && data.description.size() <= 5000 &&
             data.stats is map &&
             data.stats.keys().hasAll(['polyCount', 'textures', 'rigged', 'animated', 'uvMapped']) &&
             data.formats is list && data.formats.size() <= 20;
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      // Create is public (Guest Checkout)
      allow create: if isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == request.time;
      // Read is restricted to the one who placed it or admin
      allow get: if isAdmin() || (incoming() == null && existing().customerEmail == request.auth.token.email && request.auth.token.email_verified == true);
      // List/Query must be secured
      allow list: if isAdmin() || (resource.data.customerEmail == request.auth.token.email && request.auth.token.email_verified == true);
      // Orders are immutable
      allow update, delete: if isAdmin(); 
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerEmail', 'items', 'total', 'status', 'createdAt']) &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.customerEmail is string && data.customerEmail.size() <= 200 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['completed', 'cancelled', 'pending'];
    }

    // --- STATS ---
    match /stats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ADMINS ---
    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false; // Only manageable through Firebase Console or Cloud Functions
    }
  }
}
